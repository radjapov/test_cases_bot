# Telegram Bot Token from @BotFather
BOT_TOKEN="YOUR_BOT_TOKEN"

# Gemini API Key for text generation
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Database URL. For SQLite: "sqlite+aiosqlite:///./db.sqlite3"
# For async PostgreSQL: "postgresql+asyncpg://user:password@host/dbname"
DATABASE_URL="sqlite+aiosqlite:///./db.sqlite3"

# List of allowed Telegram user IDs (comma-separated)
# Example: "12345678,87654321"
ALLOWED_TELEGRAM_IDS=""

# Bot's mode: "polling" or "webhook"
BOT_MODE="polling"

# Redis connection settings
REDIS_HOST="localhost"
REDIS_PORT="6379"

# --- Webhook settings (if BOT_MODE is "webhook") ---
# Base URL for the webhook, e.g., "https://your.domain.com"
WEBHOOK_BASE_URL=""
# Path for the webhook, e.g., "/webhook/bot"
WEBHOOK_PATH=""

# Logging level
LOG_LEVEL="INFO"
